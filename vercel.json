{
    "version": 2,
    "builds": [
        {
            "src": "api/hlf.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/hlf.php",
            "dest": "/api/hlf.py"
        },
        {
            "src": "/api/hlf.php",
            "dest": "/api/hlf.py"
        }
    ]
}
